{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "gateways": {
      "$gatewayId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "pairingTokens": {
      "$token": {
        ".write": "auth != null",
        ".read": "false"
      }
    }
  }
}
